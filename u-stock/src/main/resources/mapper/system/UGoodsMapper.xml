<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.UGoodsMapper">
    
    <resultMap type="UGoods" id="UGoodsResult">
        <result property="sid"    column="sid"    />
        <result property="sName"    column="s_name"    />
        <result property="sImg"    column="s_img"    />
        <result property="sLb"    column="s_lb"    />
        <result property="sTime"    column="s_time"    />
    </resultMap>

    <sql id="selectUGoodsVo">
        select sid, s_name, s_img, s_lb, s_time from u_goods
    </sql>

    <select id="selectUGoodsList" parameterType="UGoods" resultMap="UGoodsResult">
        <include refid="selectUGoodsVo"/>
        <where>  
            <if test="sName != null  and sName != ''"> and s_name like concat('%', #{sName}, '%')</if>
            <if test="sImg != null  and sImg != ''"> and s_img = #{sImg}</if>
            <if test="sLb != null  and sLb != ''"> and s_lb = #{sLb}</if>
            <if test="sTime != null "> and s_time = #{sTime}</if>
        </where>
    </select>
    
    <select id="selectUGoodsBySid" parameterType="String" resultMap="UGoodsResult">
        <include refid="selectUGoodsVo"/>
        where sid = #{sid}
    </select>
        
    <insert id="insertUGoods" parameterType="UGoods">
        insert into u_goods
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="sid != null">sid,</if>
            <if test="sName != null">s_name,</if>
            <if test="sImg != null">s_img,</if>
            <if test="sLb != null">s_lb,</if>

            s_time,
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="sid != null">#{sid},</if>
            <if test="sName != null">#{sName},</if>
            <if test="sImg != null">#{sImg},</if>
            <if test="sLb != null">#{sLb},</if>
            now(),
         </trim>
    </insert>

    <update id="updateUGoods" parameterType="UGoods">
        update u_goods
        <trim prefix="SET" suffixOverrides=",">
            <if test="sName != null">s_name = #{sName},</if>
            <if test="sImg != null">s_img = #{sImg},</if>
            <if test="sLb != null">s_lb = #{sLb},</if>
            <if test="sTime != null">s_time = #{sTime},</if>
        </trim>
        where sid = #{sid}
    </update>

    <delete id="deleteUGoodsBySid" parameterType="String">
        delete from u_goods where sid = #{sid}
    </delete>

    <delete id="deleteUGoodsBySids" parameterType="String">
        delete from u_goods where sid in 
        <foreach item="sid" collection="array" open="(" separator="," close=")">
            #{sid}
        </foreach>
    </delete>

</mapper>