<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.ULogMapper">
    
    <resultMap type="ULog" id="ULogResult">
        <result property="id"    column="id"    />
        <result property="sid"    column="sid"    />
        <result property="sName"    column="s_name"    />
        <result property="sImg"    column="s_img"    />
        <result property="sLb"    column="s_lb"    />
        <result property="gid"    column="gid"    />
        <result property="cname"    column="cname"    />
        <result property="sAddress"    column="s_address"    />
        <result property="sContenct"    column="s_contenct"    />
        <result property="snum"    column="snum"    />
        <result property="stype"    column="stype"    />
        <result property="uname"    column="uname"    />
        <result property="tim"    column="tim"    />
    </resultMap>

    <sql id="selectULogVo">
        select id, sid, s_name, s_img, s_lb, gid, cname, s_address, s_contenct, snum, stype, uname, tim from u_log
    </sql>

    <select id="selectULogList" parameterType="ULog" resultMap="ULogResult">
        <include refid="selectULogVo"/>
        <where>  
            <if test="sid != null  and sid != ''"> and sid = #{sid}</if>
            <if test="sName != null  and sName != ''"> and s_name like concat('%', #{sName}, '%')</if>
            <if test="sImg != null  and sImg != ''"> and s_img = #{sImg}</if>
            <if test="sLb != null  and sLb != ''"> and s_lb = #{sLb}</if>
            <if test="gid != null  and gid != ''"> and gid = #{gid}</if>
            <if test="cname != null  and cname != ''"> and cname like concat('%', #{cname}, '%')</if>
            <if test="sAddress != null  and sAddress != ''"> and s_address = #{sAddress}</if>
            <if test="sContenct != null  and sContenct != ''"> and s_contenct = #{sContenct}</if>
            <if test="snum != null  and snum != ''"> and snum = #{snum}</if>
            <if test="stype != null  and stype != ''"> and stype = #{stype}</if>
            <if test="uname != null  and uname != ''"> and uname like concat('%', #{uname}, '%')</if>
            <if test="tim != null "> and tim = #{tim}</if>
        </where>
    </select>
    
    <select id="selectULogById" parameterType="String" resultMap="ULogResult">
        <include refid="selectULogVo"/>
        where id = #{id}
    </select>



    <select id="tj" resultType="java.util.Map" parameterType="String">
        select if(ISNULL(u_log.snum)=1,0,u_log.snum) snum ,s_time.dayStr from s_time LEFT JOIN u_log on CONVERT (u_log.tim, date )= s_time.dayStr and  u_log.stype=#{k}
    </select>
        
    <insert id="insertULog" parameterType="ULog">
        insert into u_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="sid != null">sid,</if>
            <if test="sName != null">s_name,</if>
            <if test="sImg != null">s_img,</if>
            <if test="sLb != null">s_lb,</if>
            <if test="gid != null">gid,</if>
            <if test="cname != null">cname,</if>
            <if test="sAddress != null">s_address,</if>
            <if test="sContenct != null">s_contenct,</if>
            <if test="snum != null">snum,</if>
            <if test="stype != null">stype,</if>
            <if test="uname != null">uname,</if>
            <if test="tim != null">tim,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="sid != null">#{sid},</if>
            <if test="sName != null">#{sName},</if>
            <if test="sImg != null">#{sImg},</if>
            <if test="sLb != null">#{sLb},</if>
            <if test="gid != null">#{gid},</if>
            <if test="cname != null">#{cname},</if>
            <if test="sAddress != null">#{sAddress},</if>
            <if test="sContenct != null">#{sContenct},</if>
            <if test="snum != null">#{snum},</if>
            <if test="stype != null">#{stype},</if>
            <if test="uname != null">#{uname},</if>
            <if test="tim != null">#{tim},</if>
         </trim>
    </insert>

    <update id="updateULog" parameterType="ULog">
        update u_log
        <trim prefix="SET" suffixOverrides=",">
            <if test="sid != null">sid = #{sid},</if>
            <if test="sName != null">s_name = #{sName},</if>
            <if test="sImg != null">s_img = #{sImg},</if>
            <if test="sLb != null">s_lb = #{sLb},</if>
            <if test="gid != null">gid = #{gid},</if>
            <if test="cname != null">cname = #{cname},</if>
            <if test="sAddress != null">s_address = #{sAddress},</if>
            <if test="sContenct != null">s_contenct = #{sContenct},</if>
            <if test="snum != null">snum = #{snum},</if>
            <if test="stype != null">stype = #{stype},</if>
            <if test="uname != null">uname = #{uname},</if>
            <if test="tim != null">tim = #{tim},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteULogById" parameterType="String">
        delete from u_log where id = #{id}
    </delete>

    <delete id="deleteULogByIds" parameterType="String">
        delete from u_log where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>