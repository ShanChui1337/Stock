<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.UStoreMapper">
    
    <resultMap type="UStore" id="UStoreResult">
        <result property="uid"    column="uid"    />
        <result property="sName"    column="s_name"    />
        <result property="sAddress"    column="s_address"    />
        <result property="sContenct"    column="s_contenct"    />
    </resultMap>

    <sql id="selectUStoreVo">
        select uid, s_name, s_address, s_contenct from u_store
    </sql>

    <select id="selectUStoreList" parameterType="UStore" resultMap="UStoreResult">
        <include refid="selectUStoreVo"/>
        <where>  
            <if test="sName != null  and sName != ''"> and s_name like concat('%', #{sName}, '%')</if>
            <if test="sAddress != null  and sAddress != ''"> and s_address = #{sAddress}</if>
            <if test="sContenct != null  and sContenct != ''"> and s_contenct = #{sContenct}</if>
        </where>
    </select>
    
    <select id="selectUStoreByUid" parameterType="String" resultMap="UStoreResult">
        <include refid="selectUStoreVo"/>
        where uid = #{uid}
    </select>
   <!-- selectCount-->

    <select id="selectCount" parameterType="String" resultType="java.util.Map">
        select count(*) re from  u_stock LEFT JOIN u_store on u_store.uid=u_stock.gid where u_store.uid=#{uid}
    </select>


    <insert id="insertUStore" parameterType="UStore">
        insert into u_store
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="uid != null">uid,</if>
            <if test="sName != null and sName != ''">s_name,</if>
            <if test="sAddress != null and sAddress != ''">s_address,</if>
            <if test="sContenct != null and sContenct != ''">s_contenct,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="uid != null">#{uid},</if>
            <if test="sName != null and sName != ''">#{sName},</if>
            <if test="sAddress != null and sAddress != ''">#{sAddress},</if>
            <if test="sContenct != null and sContenct != ''">#{sContenct},</if>
         </trim>
    </insert>

    <update id="updateUStore" parameterType="UStore">
        update u_store
        <trim prefix="SET" suffixOverrides=",">
            <if test="sName != null and sName != ''">s_name = #{sName},</if>
            <if test="sAddress != null and sAddress != ''">s_address = #{sAddress},</if>
            <if test="sContenct != null and sContenct != ''">s_contenct = #{sContenct},</if>
        </trim>
        where uid = #{uid}
    </update>

    <delete id="deleteUStoreByUid" parameterType="String">
        delete from u_store where uid = #{uid}
    </delete>

    <delete id="deleteUStoreByUids" parameterType="String">
        delete from u_store where uid in 
        <foreach item="uid" collection="array" open="(" separator="," close=")">
            #{uid}
        </foreach>
    </delete>

</mapper>